{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    }
  },
  "rewrites": [
    {
      "source": "/_/backend",
      "destination": "/api"
    },
    {
      "source": "/_/backend/:path*",
      "destination": "/api/:path*"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "installCommand": "npm install --prefix backend && npm install --prefix frontend"
}
